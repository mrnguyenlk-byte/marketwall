// MarketWall — PostgreSQL schema (Sprint 3)
// Broker catalog remains static JSON; Broker model is forward-looking for future seed/sync.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

/// Auth-ready user (watchlist + alerts when features are enabled).
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(user)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  watchlists Watchlist[]
  alerts     Alert[]
}

/// NextAuth / Auth.js — OAuth account linkage (credentials-only app uses User.passwordHash).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// NextAuth / Auth.js — database session (JWT strategy used for credentials; table kept for adapter).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// NextAuth / Auth.js — email verification / magic-link tokens.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@index([userId])
}

/// Symbol codes align with `WatchlistSymbol` in `lib/watchlist.ts`.
model WatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String
  symbol      String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
  @@index([watchlistId])
}

/// Price/change alerts — forward-looking (no UI yet).
model Alert {
  id            String   @id @default(cuid())
  userId        String
  symbol        String
  condition     String
  targetPrice   Float?
  targetPercent Float?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
}

/// Mirrors `BrokerRecord` in `types/broker.ts` — admin CMS can seed/sync from static catalog.
model Broker {
  slug            String   @id
  name            String
  initials        String
  category        String
  websiteUrl      String
  affiliateUrl    String?
  logoUrl         String?
  description     String?  @db.Text
  pros            Json?
  cons            Json?
  rating          Float
  trustScore      Int
  minDeposit      String
  minDepositValue Float
  license         Json
  licenseTags     String[]
  spread          String
  spreadValue     Float
  platforms       Json
  platformTags    String[]
  leverage        String
  executionType   Json
  region          Json
  accountType     Json
  offer           Json
  withdrawalTime  Json
  badges          String[]
  featured        Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Singleton site contact / social / footer content (admin CMS).
model SiteSettings {
  id            String   @id @default("singleton")
  email         String?
  phone         String?
  telegramLink  String?
  facebookLink  String?
  zaloLink      String?
  communityCta  String?  @db.Text
  footerContent String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Contact form submissions from the public site.
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  subject   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([read])
}

/// Daily analysis automation run history.
model AutomationLog {
  id             String   @id @default(cuid())
  date           String
  status         String
  telegramStatus String?
  facebookStatus String?
  facebookError  String?
  facebookErrorCode String?
  errors         Json?
  createdAt      DateTime @default(now())

  @@index([date])
  @@index([createdAt])
}

/// Outbound broker click analytics — replaces `data/broker-clicks.jsonl`.
model BrokerClick {
  id        String   @id @default(uuid())
  slug      String
  timestamp DateTime @default(now())
  referer   String?
  userAgent String?
  source    String?
  campaign  String?

  @@index([slug])
  @@index([timestamp])
}

/// Post-market proprietary trading (EOD) — CafeF GH3 sync (Sprint 26).
model ProprietaryTradingDaily {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  symbol     String
  buyValue   Float
  sellValue  Float
  netValue   Float
  buyVolume  Float
  sellVolume Float
  source     String   @default("cafef")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, symbol, source])
  @@index([date])
  @@index([symbol])
}
