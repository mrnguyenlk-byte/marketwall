# Copy to .env.local and fill in values. Never commit .env.local.

# Twelve Data — forex, overview, US heatmap, realtime WS (https://twelvedata.com)
TWELVE_DATA_API_KEY=your_key_here

# Finnhub — market news & calendar (https://finnhub.io)
FINNHUB_API_KEY=your_key_here

# Trading Economics — calendar / macro (https://tradingeconomics.com)
# Also accepts TRADING_ECONOMICS_KEY as an alias.
TRADING_ECONOMICS_API_KEY=your_key_here

# PostgreSQL — Prisma (broker clicks, watchlist, auth)
# Local example: postgresql://postgres:postgres@localhost:5432/marketwall
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Auth.js / NextAuth v5 — credentials login + session JWT
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
# App URL (local dev)
NEXTAUTH_URL=http://localhost:3000

# Header LIVE nav — offline link + platform URLs (see lib/livestream-config.ts)
# LIVESTREAM_FACEBOOK_PAGE=https://www.facebook.com/your-page
# NEXT_PUBLIC_LIVESTREAM_FACEBOOK_PAGE=https://www.facebook.com/your-page
# LIVESTREAM_YOUTUBE_URL=https://www.youtube.com/@your-channel/live
# LIVESTREAM_FACEBOOK_LIVE_URL=https://www.facebook.com/your-page/live
# LIVESTREAM_TIKTOK_URL=https://www.tiktok.com/@your-handle/live
# Manual live overrides when auto-detection is unavailable (true|false)
# LIVESTREAM_YOUTUBE=true
# LIVESTREAM_FACEBOOK=false
# LIVESTREAM_TIKTOK=false
# Optional YouTube Data API key for live detection
# YOUTUBE_API_KEY=your_key_here
